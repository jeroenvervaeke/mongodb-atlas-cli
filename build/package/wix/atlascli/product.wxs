<?xml version="1.0"?>

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
   <Product Id="*" UpgradeCode="5fa77b90-82f0-4a14-bec4-08b8a1a07b19"
      Name="MongoDB Atlas CLI"
      Version="{{.Version}}"
      Manufacturer="MongoDB, Inc."
      Language="1033">
      <Package InstallerVersion="200" Compressed="yes" Comments="Windows Installer Package"
         InstallScope="perMachine" />
      <Media Id="1" Cabinet="product.cab" EmbedCab="yes" />
      <Upgrade Id="5fa77b90-82f0-4a14-bec4-08b8a1a07b19">
         <UpgradeVersion Minimum="{{.Version}}" OnlyDetect="yes" Property="NEWERVERSIONDETECTED" />
         <UpgradeVersion Minimum="0.0.0" Maximum="{{.Version}}" IncludeMinimum="yes"
            IncludeMaximum="no"
            Property="OLDERVERSIONBEINGUPGRADED" />
      </Upgrade>
      <Condition Message="A newer version of this software is already installed.">NOT
         NEWERVERSIONDETECTED</Condition>
      <Directory Id="TARGETDIR" Name="SourceDir">
         <Directory Id="ProgramFilesFolder">
            <Directory Id="INSTALLDIR" Name="MongoDB Atlas CLI">
               <Component Id="ApplicationFiles" Guid="cac1e5b1-6547-4c47-a68c-17a5b84dd87b">
                  <File Id="ApplicationFile0" Source="{{.Binary}}.exe" />
                  <File Id="ApplicationFile1" Source="../../msi/installer" />
               </Component>
            </Directory>
         </Directory>
         <Component Id="ENVS" Guid="40df386e-df29-413f-8218-0a2904d0d9a4">
            <Environment Id="ENV0"
               Name="PATH"
               Value="[INSTALLDIR]"
               Permanent="yes"
               Part="last"
               Action="set"
               System="no" />
         </Component>
      </Directory>
      <SetProperty Id="AddToPath" Before="AddToPath" Sequence="execute" Value="&quot;powershell.exe&quot; -Command &quot;New-Item C:\\temp\\powershell-test.txt&quot;" />
      <CustomAction Id="AddToPath" BinaryKey="WixCA" DllEntry="WixQuietExec" Exeucute="deferred" Return="ignore" Impersonate="yes" />
      <InstallExecuteSequence>
         <RemoveExistingProducts After="InstallValidate" />
         <Custon Action="AddToPath" After="InstallFinalize" />
      </InstallExecuteSequence>
      <Feature Id="DefaultFeature" Level="1">
         <ComponentRef Id="ENVS" />
         <ComponentRef Id="ApplicationFiles" />
      </Feature>
      <UI>
         <!-- Define the installer UI -->
         <UIRef Id="WixUI_HK" />
      </UI>
      <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />
      <!-- this should help to propagate env var changes -->
      <CustomActionRef Id="WixBroadcastEnvironmentChange" />
   </Product>
</Wix>